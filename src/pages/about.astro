---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { brains } from '../data/brains';
import { SITE } from '../data/site';
---

<BaseLayout title="About — Labzzy">
  <div class="page">
    <main class="main">
      <div class="two-col">

        <!-- @about -->
        <section class="col-about">
          <h1 class="section-title">@about</h1>

          <div class="about-body">
            <p>
              We are Labzzy, a product design and development studio. We craft thoughtful
              digital experiences — from early concept to polished product — with a bias
              for simplicity, craft, and speed.
            </p>
            <p>
              Whether you need a brand-new product built from scratch or an existing one
              refined, we bring the same rigour and care to every engagement.
            </p>
          </div>

          <div class="social">
            <span class="social-label">Stay tuned on</span>
            <a href={SITE.linkedinUrl} class="social-link" target="_blank" rel="noopener">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                  stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="2" y="9" width="4" height="12"
                  stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="4" cy="4" r="2"
                  stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <strong>Labzzy</strong>
            </a>
          </div>
        </section>

        <!-- @brains -->
        <section class="col-brains">
          <h2 class="section-title">@brains</h2>

          <ul class="brains-list">
            {brains.map((brain) => (
              <li class="brain-item">
                {brain.image ? (
                  <img src={brain.image} alt={brain.name} class="avatar avatar-img" />
                ) : (
                  <div
                    class="avatar avatar-color"
                    style={`background: ${brain.color}`}
                    aria-hidden="true"
                  ></div>
                )}

                <div class="brain-info">
                  <strong class="brain-name">{brain.name}</strong>
                  <span class="brain-role">{brain.role}</span>
                  {brain.bio && <p class="brain-bio">{brain.bio}</p>}
                </div>
              </li>
            ))}
          </ul>
        </section>

      </div>
    </main>

    <Footer activePage="about" />
  </div>
</BaseLayout>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .main {
    flex: 1;
    padding: clamp(60px, 10vw, 159px) 24px 60px;
  }

  .two-col {
    max-width: var(--content-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 60px;
    align-items: start;
  }

  @media (min-width: 900px) {
    .main {
      padding: 159px 45px 60px;
    }

    .two-col {
      /* Figma: @about is 650px wide, gap ~106px, @brains fills the rest */
      grid-template-columns: 650px 1fr;
      gap: 106px;
    }
  }

  /* ── Section titles (@about / @brains) ── */
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, var(--text-display));
    font-weight: 700;
    font-style: normal;
    line-height: normal;
    color: var(--color-text);
    margin-bottom: 40px;
  }

  /* ── About body ── */
  .about-body {
    font-family: var(--font-display);
    font-size: var(--text-body);
    font-weight: 300;
    font-style: normal;
    line-height: 1.65;
    color: var(--color-text);
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 60px;
  }

  /* ── Social ── */
  .social {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .social-label {
    font-family: var(--font-ui);
    font-size: var(--text-body);
    color: var(--color-text);
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-ui);
    font-size: var(--text-body);
    color: var(--color-text);
    text-decoration: none;
  }

  .social-link:hover {
    text-decoration: underline;
  }

  /* ── Brains list ── */
  .brains-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .brain-item {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .avatar-img {
    object-fit: cover;
  }

  .brain-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .brain-name {
    font-family: var(--font-display);
    font-size: var(--text-body);
    font-weight: 700;
    font-style: normal;
    line-height: normal;
    color: var(--color-text);
  }

  .brain-role {
    font-family: var(--font-display);
    font-size: var(--text-body);
    font-weight: 400;
    font-style: normal;
    line-height: normal;
    color: var(--color-text);
  }

  .brain-bio {
    font-family: var(--font-ui);
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-top: 6px;
  }
</style>
